{
  "private": true,
  "scripts": {
    "dev": "next dev ",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:start": "pnpx supabase start --exclude vector",
    "db:stop": "pnpx supabase stop",
    "db:migration:new": "pnpx supabase migration new",
    "db:migration:gen": "pnpx supabase db diff --use-migra",
    "db:migration:apply": "pnpx supabase db push",
    "db:migration:reset": "pnpx supabase db reset",
    "db:seed": "pnpx ts-node supabase/seed.ts",
